%%{init: {"theme": "default"}}%%
classDiagram
    %% ── Vehicle Hierarchy ───────────────────────────────────────────────────
    class Vehicle {
        <<abstract>>
        #string licensePlate
        +getPlate() string
        +getType() VehicleType*
        +getTypeName() string*
    }

    class Motorcycle {
        +getType() VehicleType
        +getTypeName() string
    }

    class Car {
        +getType() VehicleType
        +getTypeName() string
    }

    class Truck {
        +getType() VehicleType
        +getTypeName() string
    }

    Vehicle <|-- Motorcycle
    Vehicle <|-- Car
    Vehicle <|-- Truck

    %% ── Data Records ────────────────────────────────────────────────────────
    class ParkingSlot {
        +int slotId
        +VehicleType accepts
        +string zone
        +SlotStatus status
    }

    class ActiveSession {
        +unique_ptr~Vehicle~ vehicle
        +int slotId
        +time_t entryTime
    }

    class CompletedTransaction {
        +string plate
        +VehicleType type
        +int slotId
        +time_t entryTime
        +time_t exitTime
        +long long billedHours
        +double rateApplied
        +double totalFee
    }

    %% ── Central Manager ─────────────────────────────────────────────────────
    class ParkingSystem {
        -unordered_map~int,ParkingSlot~ slots
        -unordered_map~int,queue~ freeQueues
        -unordered_map~string,ActiveSession~ activeSessions
        -vector~CompletedTransaction~ transactions
        -unordered_map~int,double~ tariffs
        -typeKey(VehicleType) int$
        -computeBilledHours(time_t,time_t) long long$
        +addSlot(int, VehicleType, string) bool
        +listAllSlots()
        +registerEntry(string, VehicleType, time_t)
        +registerExit(string, time_t)
        +updateTariff(VehicleType, double)
        +showTariffs()
        +reportAvailableSlots()
        +reportActiveParking()
        +reportTransactionHistory()
        +reportDailyRevenue()
        +hasSlots() bool
    }

    %% ── Relationships ───────────────────────────────────────────────────────
    ParkingSystem "1" *-- "0..*" ParkingSlot       : manages
    ParkingSystem "1" *-- "0..*" ActiveSession      : tracks
    ParkingSystem "1" *-- "0..*" CompletedTransaction : records
    ActiveSession "1" *-- "1"   Vehicle             : owns

    %% ── Validation Namespace ────────────────────────────────────────────────
    class io {
        <<namespace>>
        +readInt(string, long, long) long
        +readNonEmpty(string) string
        +readPositiveDouble(string) double
        +readVehicleType(string) VehicleType
        +readDateTime(string) time_t
        -flushInput()
        -readLine(string, string) bool
        -daysInMonth(int, int) int
    }

    class display {
        <<namespace>>
        +subHeader(string)
        +ruler(char)
        +ok(string)
        +err(string)
        +note(string)
    }
