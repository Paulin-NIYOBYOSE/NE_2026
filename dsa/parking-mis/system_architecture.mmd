%%{init: {"theme": "default", "themeVariables": {"fontSize": "14px"}}}%%
graph TB
    subgraph USER["User Interface Layer"]
        UI["Console I/O\n(stdin / stdout)"]
        MM["Main Menu\n(options 0–7)"]
        RM["Reports Sub-Menu\n(options 0–4)"]
    end

    subgraph VALIDATE["Input & Validation Layer  (namespace io)"]
        IV_INT["readInt()\nInteger with range check"]
        IV_STR["readNonEmpty()\nNon-empty string"]
        IV_DBL["readPositiveDouble()\nPositive finite double"]
        IV_VT["readVehicleType()\nMenu 1–3"]
        IV_DT["readDateTime()\nYYYY-MM-DD HH:MM\nno future dates"]
    end

    subgraph CORE["Business Logic Layer  (class ParkingSystem)"]
        SC["Slot Configuration\naddSlot()\nlistAllSlots()"]
        VE["Vehicle Entry\nregisterEntry()"]
        VX["Vehicle Exit & Payment\nregisterExit()"]
        TM["Tariff Management\nupdateTariff()\nshowTariffs()"]
        RP["Reporting Engine\nreportAvailableSlots()\nreportActiveParking()\nreportTransactionHistory()\nreportDailyRevenue()"]
    end

    subgraph OOP["OOP Hierarchy  (Vehicle)"]
        VB["Vehicle\n(abstract base)"]
        MC["Motorcycle"]
        CA["Car"]
        TR["Truck"]
        VB --> MC
        VB --> CA
        VB --> TR
    end

    subgraph DSA["In-Memory Data Structures"]
        DS1["unordered_map&lt;int, ParkingSlot&gt;\nslots"]
        DS2["unordered_map&lt;int, queue&lt;int&gt;&gt;\nfreeQueues"]
        DS3["unordered_map&lt;string, ActiveSession&gt;\nactiveSessions"]
        DS4["vector&lt;CompletedTransaction&gt;\ntransactions"]
        DS5["unordered_map&lt;int, double&gt;\ntariffs"]
    end

    UI --> MM
    MM --> RM
    MM --> VALIDATE
    VALIDATE --> CORE
    CORE --> OOP
    SC --> DS1
    SC --> DS2
    VE --> DS1
    VE --> DS2
    VE --> DS3
    VX --> DS1
    VX --> DS2
    VX --> DS3
    VX --> DS4
    TM --> DS5
    RP --> DS1
    RP --> DS3
    RP --> DS4
    RP --> DS5
